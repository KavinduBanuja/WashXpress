rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Profile photos: owner can read/write their own photo; any authenticated user can read
    match /profile-photos/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid.replace('.jpg', '');
    }

    // Deny everything else by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
